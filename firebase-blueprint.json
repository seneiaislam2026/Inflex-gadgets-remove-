{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "category", "price", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "source": { "type": "string", "enum": ["website", "facebook", "manual"] },
        "deliveryAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "items", "total", "deliveryAddress"]
    },
    "ImportRequest": {
      "title": "Import Request",
      "description": "A request for a product from abroad",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productName": { "type": "string" },
        "productPhoto": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "shipped"] },
        "probableDeliveryDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products available"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed"
    },
    "/importRequests/{requestId}": {
      "schema": { "$ref": "#/entities/ImportRequest" },
      "description": "International product requests"
    }
  }
}
