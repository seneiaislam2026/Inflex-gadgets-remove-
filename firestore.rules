rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email.lower() == 'admin@inflex.com' ||
        request.auth.token.email.lower() == 'seneiaislam@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) 
        && data.keys().hasOnly(['name', 'email', 'role', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role in ['user', 'admin']
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (data.get('updatedAt', request.time) == request.time || data.updatedAt is timestamp);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'category', 'price', 'isFeatured', 'images', 'createdAt', 'updatedAt']) 
        && data.keys().hasOnly(['name', 'description', 'category', 'price', 'discountPrice', 'stock', 'isFeatured', 'images', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.category is string && data.category.size() <= 50
        && data.price is number
        && data.isFeatured is bool
        && data.images is list && data.images.size() <= 10 && data.images.size() > 0 && data.images[0] is string
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (data.updatedAt == request.time || data.updatedAt is timestamp)
        && data.get('discountPrice', 0) is number
        && data.get('stock', 0) is number;
    }

    function isValidOrder(data) {
      // Relaxed hasAll to accommodate older documents that might be missing certain fields
      return data.keys().hasAll(['status', 'items', 'total', 'deliveryAddress', 'createdAt', 'updatedAt']) 
        && data.keys().hasOnly(['userId', 'status', 'items', 'total', 'deliveryAddress', 'createdAt', 'updatedAt', 'paymentMethod', 'deliveryFee', 'source', 'isFake', 'customDeliveryDate'])
        && (data.get('userId', null) == null || (data.userId is string && (data.userId == request.auth.uid || isAdmin())))
        && data.status in ['pending', 'confirmed', 'processing', 'shipped', 'delivered', 'cancelled']
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number 
        && data.deliveryAddress is map 
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (data.updatedAt == request.time || data.updatedAt is timestamp)
        && (data.get('paymentMethod', '') is string)
        && (data.get('deliveryFee', 0) is number)
        && (data.get('source', '') is string)
        && (data.get('isFake', false) is bool)
        && (data.get('customDeliveryDate', '') is string);
    }

    function isValidImportRequest(data) {
      return data.keys().hasAll(['userId', 'productName', 'status', 'createdAt', 'updatedAt']) 
        && data.keys().hasOnly(['userId', 'productName', 'productPhoto', 'description', 'status', 'probableDeliveryDate', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId == request.auth.uid
        && data.productName is string && data.productName.size() <= 200
        && data.status in ['pending', 'approved', 'rejected', 'shipped']
        && (data.createdAt == request.time || data.createdAt is timestamp)
        && (data.updatedAt == request.time || data.updatedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming()) && (
        incoming().role == 'user' || (incoming().role == 'admin' && request.auth.token.email.lower() == 'admin@inflex.com')
      );
      allow update: if isSignedIn() && isValidUser(incoming()) && (
        isAdmin() ||
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) && incoming().role == existing().role)
      );
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && incoming().diff(existing()).affectedKeys().hasAny(['name', 'description', 'category', 'price', 'isFeatured', 'images', 'updatedAt']);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && (isAdmin() || incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isValidOrder(incoming()) && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'cancelled' && existing().status == 'pending')
      );
    }

    match /importRequests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(requestId) && isValidImportRequest(incoming());
      allow update: if isAdmin() && isValidImportRequest(incoming());
      allow delete: if isAdmin();
    }
  }
}
